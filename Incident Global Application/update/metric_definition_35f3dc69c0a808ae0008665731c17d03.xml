    <metric_definition action="INSERT_OR_UPDATE">
        <active>true</active>
        <description>Overly simplified definition of first call resolution.  &#13;
&#13;
If the incident is inactive and the update count (sys_mod_count) is zero, create one of these.</description>
        <field>incident_state</field>
        <name>First Call Resolution</name>
        <number>MTRC0000005</number>
        <order>100</order>
        <script><![CDATA[// variables available
// current: GlideRecord -  target incident
// definition: GlideRecord -  (this row)
if (current.sys_mod_count == 0) {
  var value = false;
  if (!current.active)
      value = true;
     
  createMetric(value);
}

function createMetric(value) {
  var mi = new MetricInstance(definition, current);
  if (mi.metricExists()) 
    return;

  var gr = mi.getNewRecord();
  gr.field_value = value;
  gr.field = null;
  gr.calculation_complete = true;
  gr.insert();
}

]]></script>
